# copy to .env and fill in the blanks. everything here is safe to commit — placeholders
# only, no real secrets.
#
# there's no .env on the appliance. the systemd units (app, horizon, reverb) get their
# environment from the nix module, and secrets come out of sops-nix — or get generated
# on first boot (APP_KEY and the reverb id/key/secret). if you're deploying that way, see
# docs/deploy (not written yet). this file is just the reference list of what the app reads.

APP_NAME=Laravel
APP_ENV=local
APP_KEY=                       # php artisan key:generate writes this. never commit a real one.
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# postgres holds kixctl's own state only (users, roles, sessions, jobs) — never a copy
# of incus state. lives on the .46 box.
DB_CONNECTION=pgsql
DB_HOST=192.168.2.46
DB_PORT=5432
DB_DATABASE=kixctl
DB_USERNAME=kixctl
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# queues, cache and broadcasting all run through valkey + reverb (wired in P2-C).
BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

# valkey on the .46 box. cache and queues use separate redis DBs, but that split is set
# in config/database.php, not here.
REDIS_CLIENT=phpredis
REDIS_HOST=192.168.2.46
REDIS_PASSWORD=null
REDIS_PORT=6379
# has to stay above the horizon job timeout (1800s) or a long image pull gets re-released
# as stalled while it's still running.
REDIS_QUEUE_RETRY_AFTER=2000

# dev talks to incus over the local unix socket because this box is a cluster member.
# prod authenticates over https with a scoped client cert — set INCUS_DRIVER=https then.
INCUS_DRIVER=socket
INCUS_SOCKET=/var/lib/incus/unix.socket

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# self-hosted reverb — the id/key/secret aren't credentials from a vendor, just a shared
# secret the app and the reverb process use to trust each other. any random values work as
# long as both sides match. install:broadcasting generates them; on the appliance they're
# generated at first boot.
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST="localhost"
REVERB_PORT=8080
# http/localhost is dev only. flips to https + wss when the admin surface goes behind tls
# (the hardening pass).
REVERB_SCHEME=http

# what the browser-side echo client reads. mirrors the reverb vars above.
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"
